{
    "python.envFile": "${workspaceFolder}/.venv",
    "python.autoComplete.extraPaths": [
        "${workspaceFolder}/src"
    ],
    "basedpyright.analysis.typeCheckingMode": "basic",
    "basedpyright.analysis.useLibraryCodeForTypes": true,
    "basedpyright.analysis.diagnosticSeverityOverrides": {
        // Esto silencia los errores de "Unknown" (lo que vimos con Matplotlib)
        "reportUnknownMemberType": "none",
        "reportUnknownVariableType": "none",
        "reportUnknownArgumentType": "none",
        "reportUnknownParameterType": "none",
        "reportUnknownReturnType": "none",
        // Esto silencia los errores de "None" (lo que vimos con set_xlabel)
        "reportArgumentType": "none",
        "reportOptionalMemberAccess": "none",
        "reportOptionalIterable": "none",
        "reportOptionalContextManager": "none",
        "reportOptionalCall": "none",
        // Mantenemos esto para evitar errores de acceso a atributos
        "reportAttributeAccessIssue": "none"
    }
}